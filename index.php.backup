                            <?php 
                            if (count($tiket) > 0):
                                $no = 1; 
                                foreach ($tiket as $row): 
                            ?>
                            <tr>
                                <td><?= $no++; ?></td>
                                <td><span class="badge bg-info text-dark"><?= htmlspecialchars($row['kode_tiket']); ?></span></td>
                                <td><?= htmlspecialchars($row['nama_pemesan']); ?></td>
                                <td><?= htmlspecialchars($row['tujuan']); ?></td>
                                <td><?= htmlspecialchars($row['tanggal']); ?></td>
                                <td>Rp <?= number_format($row['harga'], 0, ',', '.'); ?></td>
                                <td>
                                    <a href="edit.php?id=<?= $row['id']; ?>" class="btn btn-sm btn-warning">
                                        <i class="bi bi-pencil-square"></i> Edit
                                    </a>
                                    <a href="hapus.php?id=<?= $row['id']; ?>" class="btn btn-sm btn-danger" onclick="return confirm('Yakin ingin menghapus data ini?')">
                                        <i class="bi bi-trash"></i> Hapus
                                    </a>
                                </td>
                            </tr>
                            <?php 
                                endforeach; 
                            else:
                            ?>
                            <tr>
                                <td colspan="7" class="text-center text-muted">Belum ada data pemesanan</td>
                            </tr>
